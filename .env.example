# Backend Environment Variables
# Copy this file to .env (or export these as system env vars)
# and configure with your local MySQL credentials.

# Database
DB_USERNAME=root
DB_PASSWORD=your_mysql_password

# JWT
# Must be at least 32 characters for HS256 signing
JWT_SECRET=mySecretKeyForEcommerceAppThatIsAtLeast256BitsLong12345
JWT_EXPIRATION=86400000

# CORS - comma separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
